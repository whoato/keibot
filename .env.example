# Discord 봇 토큰 (Discord Developer Portal에서 발급)
DISCORD_TOKEN=your_bot_token_here

# DB 파일 경로 (기본값: kei.db)
DB_PATH=kei.db

# 개발용 테스트 서버 ID (쉼표로 구분해서 여러 개 입력 가능, 설정 시 --sync가 해당 길드들에만 즉시 반영됨)
# DEV_GUILD_IDS=guild_id_1,guild_id_2

# Gemini API 키 (Google AI Studio에서 발급)
GEMINI_API_KEY=your_gemini_api_key_here

# 케이 대화 채널 ID (해당 채널에서만 AI 대화 기능 작동)
# Discord에서 채널 우클릭 → ID 복사
CHAT_CHANNEL_ID=your_channel_id_here
